# ─────────────────────────────────────────────────────────────
# Copy to `.env` and fill in. Docker Compose reads `.env` automatically.
# ─────────────────────────────────────────────────────────────

# Postgres. Compose overrides the host to `db` for the app container;
# this value is used when running the app on the host (npm run dev).
DATABASE_URL="postgresql://hr:hr@localhost:5432/hr?schema=public"

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="dev-secret-change-me-please-0123456789abcdef"

# ── AI providers ─────────────────────────────────────────────
# Chat defaults to OpenRouter (free models). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Optional: Vercel AI Gateway (selectable as alternative chat provider).
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=""

# Embeddings are cloud-only (OpenRouter has no embeddings API).
# Used by the seed script + RAG. text-embedding-3-small -> 1536 dims.
OPENAI_API_KEY=""

# Which provider the embedding helper uses: "openai" or "gateway".
EMBEDDING_PROVIDER="openai"
