# ─────────────────────────────────────────────────────────────
# Copy to `.env` and fill in. Docker Compose reads `.env` automatically.
# ─────────────────────────────────────────────────────────────

# Postgres. Compose overrides the host to `db` for the app container;
# this value is used when running the app on the host (npm run dev).
DATABASE_URL="postgresql://hr:hr@localhost:5432/hr?schema=public"

# Auth.js — generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="dev-secret-change-me-please-0123456789abcdef"

# ── AI providers ─────────────────────────────────────────────
# Powers BOTH chat AND RAG embeddings. Get a key at https://openrouter.ai/keys
# Chat uses free :free models; embeddings use a free lightweight model
# (all-MiniLM-L6-v2, 384d). One key runs the whole demo.
OPENROUTER_API_KEY=""

# Optional: Vercel AI Gateway (selectable as an alternative chat provider).
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=""

# Optional: swap the embedding model. Safe for any OTHER 384-dim model
# (e.g. sentence-transformers/paraphrase-minilm-l6-v2). A different dimension
# needs a new Prisma migration to ALTER the halfvec column — see embeddings.ts.
# EMBEDDING_MODEL="sentence-transformers/all-minilm-l6-v2"

# ── Object storage (MinIO / S3) for Knowledge Base cover images ──
# Compose runs a `minio` service and overrides S3_ENDPOINT to http://minio:9000
# for the app container; this localhost value is used by `npm run dev` on the host.
# The MINIO_ROOT_* creds double as the app's S3 credentials in dev.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="kb-images"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
