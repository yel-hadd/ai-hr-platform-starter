// HR Platform starter — data model.
// Note: pgvector's `halfvec` column is declared via Prisma's `Unsupported` type.
// The HNSW index over it is created in the Prisma migration
// (`prisma/migrations/0_init`), since Prisma can't model an index on it.

generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url = env("DATABASE_URL")
}

enum Role {
EMPLOYEE
MANAGER
HR_ADMIN
SUPER_ADMIN
}

enum LeaveType {
VACATION
SICK
PERSONAL
}

enum LeaveStatus {
PENDING
APPROVED
REJECTED
}

/// Auth identity. One User maps to one Employee profile.
model User {
id String @id @default(cuid())
email String @unique
name String
passwordHash String
role Role @default(EMPLOYEE)
employee Employee?
createdAt DateTime @default(now())
kbCreated HrDocument[] @relation("KbCreatedBy")
kbUpdated HrDocument[] @relation("KbUpdatedBy")
kbFeedback KbFeedback[]
}

/// HR profile / org data.
model Employee {
id String @id @default(cuid())
user User @relation(fields: [userId], references: [id], onDelete: Cascade)
userId String @unique
title String
department String
location String
startDate DateTime
status EmploymentStatus @default(ACTIVE)
employmentType EmploymentType @default(FULL_TIME)
salary Int // annual, in USD — sensitive: only HR/Super can read via tools
avatarUrl String?

// Self-referential org chart.
manager Employee? @relation("Reports", fields: [managerId], references: [id])
managerId String?
reports Employee[] @relation("Reports")

leaveBalances LeaveBalance[]
leaveRequests LeaveRequest[] @relation("Requester")
approvals LeaveRequest[] @relation("Approver")
}

model LeaveBalance {
id String @id @default(cuid())
employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
employeeId String
type LeaveType
totalDays Int
usedDays Int @default(0)

@@unique([employeeId, type])
}

model LeaveRequest {
id String @id @default(cuid())
employee Employee @relation("Requester", fields: [employeeId], references: [id], onDelete: Cascade)
employeeId String
type LeaveType
startDate DateTime
endDate DateTime
days Int
reason String?
status LeaveStatus @default(PENDING)
approver Employee? @relation("Approver", fields: [approverId], references: [id])
approverId String?
createdAt DateTime @default(now())
}

/// Org-wide settings, a single row (id = "singleton"). Editable by a super admin
/// in Settings; drives currency formatting and the timezone the AI reasons in.
model OrgSettings {
  id        String   @id @default("singleton")
  currency  String   @default("MAD")
  timezone  String   @default("UTC")
  updatedAt DateTime @updatedAt
}

/// Knowledge-base lifecycle. Only PUBLISHED documents feed the RAG (HARI-62).
enum DocStatus {
DRAFT
PUBLISHED
ARCHIVED
}

/// Per-document access level (HARI-59). Mapped to roles via visibleDocTiers().
enum DocVisibility {
ALL_EMPLOYEES
MANAGERS
HR_ONLY
}

/// A KB collection groups related HR documents (e.g. "Employee Handbook").
model KbCollection {
id String @id @default(cuid())
slug String @unique
name String
description String?
order Int @default(0)
documents HrDocument[]
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}

/// HARI-58: an HR document usable by the RAG. Markdown body, chunked on publish.
model HrDocument {
id String @id @default(cuid())
slug String @unique
title String
content String // HTML source of truth (authored in BlockNote)
status DocStatus @default(DRAFT)
visibility DocVisibility @default(ALL_EMPLOYEES)
version Int @default(1) // bumped each publish (HARI-59)
tags String[] @default([]) // freeform topic tags
viewCount Int @default(0) // reader views (engagement signal)
collection KbCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
collectionId String
chunks HandbookChunk[]
// Authorship (shown on the reader + admin). SetNull so deleting a user keeps docs.
createdBy User? @relation("KbCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
createdById String?
updatedBy User? @relation("KbUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
updatedById String?
feedback KbFeedback[]
publishedAt DateTime?
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

@@index([collectionId])
@@index([status])
}

/// "Was this helpful?" — one vote per (document, user); re-voting updates it.
model KbFeedback {
id String @id @default(cuid())
document HrDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
documentId String
voter User @relation(fields: [voterId], references: [id], onDelete: Cascade)
voterId String
helpful Boolean
createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

@@unique([documentId, voterId])
}

/// RAG chunks. `embedding` is a pgvector halfvec(384). HARI-59: each chunk is
/// attached to its document, version, and (denormalized) access level so
/// retrieval can filter by tier without a join on the hot path.
model HandbookChunk {
id String @id @default(cuid())
section String // heading text
anchor String @default("") // slug of the heading → citation deep-link
content String
chunkIndex Int @default(0) // order within the document
embedding Unsupported("halfvec(384)")?
document HrDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
documentId String?
version Int @default(1)
visibility DocVisibility @default(ALL_EMPLOYEES)
createdAt DateTime @default(now())

@@index([documentId])
}

enum EmploymentStatus {
ACTIVE
ON_LEAVE
TERMINATED
}

enum EmploymentType {
FULL_TIME
PART_TIME
CONTRACTOR
}
